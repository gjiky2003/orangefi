{
  "version": "v1.0.0",
  "description": "OrangeFi Risk Scorer v1 — Weighted Component Model for Debt Consolidation Underwriting",
  "model_type": "weighted_component",
  "created_at": "2026-01-15",
  "weights": {
    "fico_score": 0.40,
    "credit_utilization": 0.15,
    "dti_ratio": 0.15,
    "income_stability": 0.15,
    "account_age": 0.10,
    "employment_stability": 0.05
  },
  "component_configs": {
    "fico_score": {
      "score_ranges": [
        {"min": 800, "max": 850, "subscore": 5},
        {"min": 740, "max": 799, "subscore": 15},
        {"min": 670, "max": 739, "subscore": 35},
        {"min": 580, "max": 669, "subscore": 65},
        {"min": 300, "max": 579, "subscore": 100}
      ],
      "description": "Inverse relationship: lower FICO = higher risk subscore"
    },
    "credit_utilization": {
      "score_ranges": [
        {"min": 0, "max": 10, "subscore": 5},
        {"min": 10, "max": 30, "subscore": 20},
        {"min": 30, "max": 50, "subscore": 40},
        {"min": 50, "max": 70, "subscore": 60},
        {"min": 70, "max": 90, "subscore": 80},
        {"min": 90, "max": 100, "subscore": 100}
      ],
      "description": "Utilization as percentage (0-100). Higher = riskier."
    },
    "dti_ratio": {
      "score_ranges": [
        {"min": 0, "max": 0.20, "subscore": 5},
        {"min": 0.20, "max": 0.28, "subscore": 20},
        {"min": 0.28, "max": 0.36, "subscore": 40},
        {"min": 0.36, "max": 0.43, "subscore": 60},
        {"min": 0.43, "max": 0.50, "subscore": 80},
        {"min": 0.50, "max": 1.00, "subscore": 100}
      ],
      "description": "DTI as decimal. Higher DTI = higher risk."
    },
    "income_stability": {
      "categorical_scores": {
        "stable": 10,
        "verified": 15,
        "regular": 20,
        "unknown": 50,
        "variable": 75,
        "seasonal": 70,
        "self_employed": 60,
        "irregular": 70,
        "unstable": 85
      },
      "description": "Income stability category. Irregular = riskier."
    },
    "account_age": {
      "score_ranges": [
        {"min": 120, "max": 999, "subscore": 5, "label": "10+ years"},
        {"min": 84, "max": 119, "subscore": 15, "label": "7-10 years"},
        {"min": 60, "max": 83, "subscore": 30, "label": "5-7 years"},
        {"min": 36, "max": 59, "subscore": 50, "label": "3-5 years"},
        {"min": 12, "max": 35, "subscore": 70, "label": "1-3 years"},
        {"min": 6, "max": 11, "subscore": 85, "label": "6-12 months"},
        {"min": 0, "max": 5, "subscore": 100, "label": "< 6 months"}
      ],
      "description": "Months of credit history. Longer = lower risk."
    },
    "employment_stability": {
      "score_ranges": [
        {"min": 120, "max": 999, "subscore": 5, "label": "10+ years"},
        {"min": 60, "max": 119, "subscore": 15, "label": "5-10 years"},
        {"min": 36, "max": 59, "subscore": 30, "label": "3-5 years"},
        {"min": 12, "max": 35, "subscore": 50, "label": "1-3 years"},
        {"min": 6, "max": 11, "subscore": 70, "label": "6-12 months"},
        {"min": 3, "max": 5, "subscore": 85, "label": "3-6 months"},
        {"min": 0, "max": 2, "subscore": 100, "label": "< 3 months"}
      ],
      "description": "Months at current employer. Longer tenure = lower risk."
    }
  },
  "booster_params": {
    "learning_rate": 0.1,
    "max_depth": 4,
    "n_estimators": 100,
    "subsample": 0.8,
    "colsample_bytree": 0.8,
    "gamma": 0.1,
    "reg_alpha": 0.01,
    "reg_lambda": 1.0,
    "min_child_weight": 5,
    "objective": "binary:logistic",
    "eval_metric": ["auc", "logloss"]
  },
  "cash_flow_blend": {
    "default_weight": 0.30,
    "thin_file_weight": 0.50,
    "thin_file_fico_threshold": 620
  },
  "metrics": {
    "val_auc": 0.783,
    "test_auc": 0.771,
    "val_logloss": 0.421,
    "test_logloss": 0.438,
    "precision_at_50": 0.72,
    "recall_at_50": 0.68,
    "f1_at_50": 0.70
  },
  "feature_importance": [
    {"feature": "fico_score", "importance": 0.387},
    {"feature": "dti_ratio", "importance": 0.178},
    {"feature": "credit_utilization", "importance": 0.152},
    {"feature": "income_stability", "importance": 0.123},
    {"feature": "account_age_months", "importance": 0.098},
    {"feature": "employment_months", "importance": 0.062}
  ],
  "decision_thresholds": {
    "auto_approve_max_score": 40,
    "manual_review_max_score": 55,
    "decline_min_score": 56
  },
  "pricing_tiers": {
    "A+": {"min_score": 0, "max_score": 15, "max_loan": 35000},
    "A": {"min_score": 16, "max_score": 30, "max_loan": 35000},
    "B": {"min_score": 31, "max_score": 45, "max_loan": 30000},
    "C": {"min_score": 46, "max_score": 60, "max_loan": 25000},
    "D": {"min_score": 61, "max_score": 75, "max_loan": 20000},
    "E": {"min_score": 76, "max_score": 100, "max_loan": 15000}
  }
}
