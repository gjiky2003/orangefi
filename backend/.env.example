# ═══════════════════════════════════════════════════════════════════════════════
# OrangeFi — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  WARNING: Required secrets with NO safe defaults
# ═══════════════════════════════════════════════════════════════════════════════
# In production, ALL of the following MUST be set via environment variables:
#   - SECRET_KEY (JWT signing — generate with: openssl rand -hex 32)
#   - ADMIN_PASSWORD (strong password, 16+ chars)
#   - ENCRYPTION_KEY (Fernet key — generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
# =============================================================================

# ── App ──
APP_NAME=OrangeFi
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# ── JWT / Security ──
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER_NAME=OrangeFi

# ── Admin ──
ADMIN_EMAIL=admin@orangefi.com
# Generate a strong password: openssl rand -base64 12
ADMIN_PASSWORD=ChangeMeInProduction123!

# ── Database ──
DATABASE_URL=postgresql+asyncpg://orangefi:orangefi@localhost:5432/orangefi
DATABASE_URL_SYNC=postgresql+psycopg2://orangefi:orangefi@localhost:5432/orangefi
DB_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Encryption (used for PII: SSN, income) ──
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=

# ── Plaid (bank verification) ──
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Stripe (payments) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Twilio (SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── SendGrid (email) ──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@orangefi.com

# ── DocuSign ──
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_AUTH_SERVER=account-d.docusign.com

# ── S3 / MinIO ──
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=orangefi-documents
S3_REGION=us-east-1

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://orangefi-frontend.onrender.com

# ── Celery (async tasks) ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Model Path ──
MODEL_DIR=./app/underwriting/models

# ── Sentry (error tracking) ──
SENTRY_DSN=
