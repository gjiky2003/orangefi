# ═══════════════════════════════════════════════════════════════════════════════
# OrangeFi Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="OrangeFi"
APP_VERSION="0.1.0"
ENVIRONMENT="development"                          # development | staging | production
DEBUG="true"                                        # Enable debug logging & stack traces
SECRET_KEY="change-me-to-a-random-256-bit-key"       # JWT signing key (min 32 chars)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# ── Database (PostgreSQL + asyncpg) ──────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://orangefi:orangefi@localhost:5432/orangefi"
DATABASE_URL_SYNC="postgresql+psycopg2://orangefi:orangefi@localhost:5432/orangefi"
DB_ECHO="false"                                     # Log all SQL queries (dev only)

# ── Redis (Cache + Celery Broker) ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# ── S3-Compatible Object Storage (MinIO in dev, AWS S3 in prod) ─────────────
S3_ENDPOINT="http://localhost:9000"                  # MinIO endpoint
S3_ACCESS_KEY="orangefi"
S3_SECRET_KEY="orangefi123"
S3_BUCKET="orangefi-documents"
S3_REGION="us-east-1"

# ── Default Admin User (created on first startup) ────────────────────────────
ADMIN_EMAIL="admin@orangefi.com"
ADMIN_PASSWORD="Admin123!"

# ── JWT Configuration ───────────────────────────────────────────────────────
JWT_ALGORITHM="HS256"                               # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=30                       # Short-lived access token
REFRESH_TOKEN_EXPIRE_DAYS=7                          # Long-lived refresh token
MFA_ISSUER_NAME="OrangeFi"                           # TOTP issuer name

# ── Encryption (AES-256 for PII at rest) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=""

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60                             # General API rate limit
RATE_LIMIT_AUTH_PER_MINUTE=5                         # Auth endpoint rate limit

# ── Plaid (Bank Account Linking) ────────────────────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ── Stripe (Payment Processing) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ── Twilio (SMS / Phone) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── SendGrid (Email) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@orangefi.com"

# ── DocuSign (E-Signatures) ─────────────────────────────────────────────────
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_CLIENT_ID=""
DOCUSIGN_CLIENT_SECRET=""
DOCUSIGN_AUTH_SERVER="account-d.docusign.com"

# ── Credit Bureau (Mock for MVP) ────────────────────────────────────────────
CREDIT_BUREAU_API_KEY=""
CREDIT_BUREAU_BASE_URL="https://api.mockbureau.com/v1"

# ── Model Directory ─────────────────────────────────────────────────────────
MODEL_DIR="./app/underwriting/models"

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
SENTRY_DSN=""

# ── Monitoring ──────────────────────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR="/tmp"
